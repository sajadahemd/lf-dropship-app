# Lightfunnels App Credentials
LF_CLIENT_ID=your_lightfunnels_client_id
LF_CLIENT_SECRET=your_lightfunnels_client_secret

# Your app's public URL (update this to your deployed URL)
APP_URL=http://localhost:3000

# Rolemall API Token (get this from your Rolemall account dashboard)
ROLEMALL_TOKEN=your_rolemall_api_token_here

# Session secret (change this to a long random string in production)
SESSION_SECRET=change_this_to_a_random_secret_string

# Port
PORT=3000
